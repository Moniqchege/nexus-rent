generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  username      String    @unique
  password_hash String
  name          String
  image         String?
  provider      String?   @default("local") 
  provider_id   String?   @unique
  plan          String?   @default("FREE")
  role          String?   @default("tenant") // landlord, tenant
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  properties    Property[]
  notifications Notification[]
  tenants       Tenant[]
}

model Session {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String    @unique
  expires_at DateTime
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Property {
  id          Int      @id @default(autoincrement())
  title       String
  location    String
  price       Float
  beds        Int
  baths       Int
  sqft        Int
  image       String?
  status      String   @default("active")
  landlordId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  landlord    User     @relation(fields: [landlordId], references: [id])
  tenants     Tenant[]
  reviews     Review[]
}

model Tenant {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  phone       String?
  userId      Int?     @unique
  propertyId  Int
  moveInDate  DateTime
  createdAt   DateTime @default(now())
  property    Property @relation(fields: [propertyId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  reviews     Review[]
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // 1-5
  comment    String?
  propertyId Int
  tenantId   Int
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
}

model Notification {
  id          Int      @id @default(autoincrement())
  message     String
  landlordId  Int
  tenantIds   Json     // array of tenant IDs as JSON
  isRead      Boolean  @default(false)
  sentAt      DateTime @default(now())
  landlord    User     @relation(fields: [landlordId], references: [id])
}

model Permission {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  category  String
  createdAt DateTime @default(now())
}

model Role {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  code        String?
  description String?
  permissions Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}


