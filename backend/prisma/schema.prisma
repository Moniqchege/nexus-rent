generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  username      String?   @unique
  phone         String?   @unique
  password_hash String
  name          String
  image         String?
  role          String?
  provider      String?  @default("local")
  provider_id   String?  @unique
  plan          String?  @default("FREE")
  firstLogin    Boolean  @default(true)
  createdAt     DateTime @default(now())
  leaseDocument  String?
  updatedAt     DateTime @updatedAt

  userProperties UserProperty[]
  sessions       Session[]
  properties     Property[]     @relation("LandlordProperties")
  Tenant         Tenant?
  Notification   Notification[]
  passwordResetTokens PasswordResetToken[]
  otpCodes       OtpCode[]
  surveys        Survey[]
  surveyResponses SurveyResponse[]
}

model Session {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  userId    Int?
  identifier String  // email or userId
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  
  @@index([identifier])
  @@index([expiresAt])
}


model Property {
  id         Int       @id @default(autoincrement())
  landlordId Int?
  landlord   User?     @relation("LandlordProperties", fields: [landlordId], references: [id])
  title      String
  location   String
  price      Float
  beds       Int
  baths      Int
  sqft       Int
  status     String    @default("active")
  amenities  Json?   
  rating     Float?
  score      Float?
  users      UserProperty[]
  Tenant     Tenant[]
  Review     Review[]
  image      String?
  floor      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Tenant {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String?
  userId     Int?     @unique
  propertyId Int
  moveInDate DateTime
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
  reviews    Review[]
}

model Review {
  id         Int       @id @default(autoincrement())
  rating     Int
  comment    String?
  propertyId Int
  tenantId   Int
  createdAt  DateTime  @default(now())
  property   Property? @relation(fields: [propertyId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  title        String 
  message    String
  landlordId Int?
  recipientIds Json
  isRead     Boolean  @default(false)
  sentAt     DateTime @default(now())
  landlord   User?    @relation(fields: [landlordId], references: [id])
}

model Permission {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  category  String
  group     String   @default("UNCATEGORIZED")      
  createdAt DateTime @default(now())
}

model Role {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  code         String?
  description  String?
  permissions  Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  UserProperty UserProperty[]
}

model UserProperty {
  id         Int @id @default(autoincrement())
  userId     Int
  propertyId Int
  roleId     Int

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  role     Role      @relation(fields: [roleId], references: [id])

  assignedAt DateTime @default(now())

  @@unique([userId, propertyId, roleId])
}

model Amenity {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  category  String
  createdAt DateTime @default(now())
}

model Survey {
  id           Int      @id @default(autoincrement())
  title        String
  questions    Json     /// Array of {question: string, type: "text"|"multiple"|"rating"}
  landlordId   Int?
  recipientIds Json    /// Array of user IDs as strings
  sentAt       DateTime @default(now())
  landlord     User?    @relation(fields: [landlordId], references: [id])

  responses SurveyResponse[]
}

model SurveyResponse {
  id           Int      @id @default(autoincrement())
  surveyId     Int
  userId       Int
  answers      Json     /// Array of responses matching questions
  submittedAt  DateTime @default(now())
  
  survey Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id])
  
  @@unique([surveyId, userId])
}

model ServiceCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  icon        String   // emoji
  description String?
  createdAt   DateTime @default(now())
  
  providers   ServiceProvider[]
}

model ServiceProvider {
  id            Int            @id @default(autoincrement())
  name          String
  phone         String
  email         String?
  categoryId    Int
  hourlyRate    Float?
  location      String?
  rating        Float?         @default(0)
  isActive      Boolean        @default(true)
  bio           String?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  category      ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@index([categoryId])
  @@index([isActive])
}

