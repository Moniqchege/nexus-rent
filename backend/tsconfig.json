{
  "compilerOptions": {
    "target": "ES2022",              
    "module": "ES2022",             
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "prisma"],
  "exclude": ["node_modules", "dist"]
}